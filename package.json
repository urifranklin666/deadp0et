{
  "name": "deadp0et",
  "version": "0.1.0",
  "private": true,
  "description": "deadp0et secure messaging backend prototype",
  "workspaces": [
    "mobile",
    "packages/*"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "check": "node --check server.js",
    "test": "node --test",
    "mobile:start": "npm --workspace mobile start",
    "mobile:web": "npm --workspace mobile run web",
    "protocol:check": "node --check packages/protocol-client/src/index.js"
  }
}
